<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="using:App.ViewModels"
        xmlns:dock="using:Dock.Avalonia.Controls"
        x:Class="App.MainWindow"
        x:DataType="viewmodels:MainWindowViewModel"
        Title="Finite Elements Method"
        Width="1320"
        Height="860"
        MinWidth="1100"
        MinHeight="680"
        CanResize="True">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Новый проект" Command="{Binding NewProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Скрепить вкладки в одно окно"
                          Command="{Binding ResetWorkspaceCommand}"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom"
                Height="28"
                Padding="10,0">
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       FontSize="12"/>
        </Border>

        <dock:DockControl x:Name="WorkspaceDock"/>
    </DockPanel>
</Window>
