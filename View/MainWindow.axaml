<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:compilerservices="using:System.Runtime.CompilerServices"
        xmlns:local="using:App"
        xmlns:viewmodels="using:App.ViewModels"
        x:DataType="viewmodels:MainWindowViewModel"
        x:Class="App.MainWindow"
        Title="App"
        Width="1200" Height="800"
        MinWidth="1000" MaxHeight="600">
    
    <DockPanel> <!--Панелька сверху-->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header ="Файл">
                <MenuItem Header="Новая задача" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="Загрузить проект..." Command="{Binding LoadProjectCommand}"/>
                <MenuItem Header="Сохранить проект..." Command="{Binding SaveProjectCommand}"/>
                <Separator />
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!--Статус задачи-->
        <Border DockPanel.Dock="Bottom"
                Background="#f0f0f0"
                Height="25"
                Padding="10,0"
                >
			<Grid>
				<TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>

        <Grid> 
            <TabControl Grid.Column="1"
                        Padding="10">
                <TabItem Header="Геометрия и сетка">
                    <StackPanel Margin="10">
                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Область расчёта" FontWeight="Bold" Margin="5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <StackPanel Margin="5">
                                        <Label Content="X Min"/>
                                        <TextBox Width="50" Text="{Binding XMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <Label Content="X Max"/>
                                        <TextBox Width="50" Text="{Binding XMax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <Label Content="Y Min"/>
                                        <TextBox Width="50" Text="{Binding YMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <Label Content="Y Max"/>
                                        <TextBox Width="50" Text="{Binding YMax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Разбиение на элементы" FontWeight="Bold" Margin="5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <StackPanel Margin="5">
                                        <Label Content="Nx"/>
                                        <TextBox Width="50" Text="{Binding Nx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <Label Content="Ny"/>
                                        <TextBox Width="50" Text="{Binding Ny, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Тип элементов" FontWeight="Bold" Margin="5"/>
                                <ComboBox ItemsSource="{Binding ElementTypes}" SelectedItem="{Binding SelectedElementType}" Margin="5" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                            <Button Content="Сохранить" Command="{Binding SaveGeometryCommand}"/>
                            <Button Content="Загрузить" Command="{Binding LoadGeometryCommand}"/>
                            <Button Content="Сбросить" Command="{Binding ResetGeometryCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Параметры задачи">
                    <StackPanel Margin="10">
                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Коэффициент диффузии" FontWeight="Bold" Margin="5"/>
                                <ComboBox ItemsSource="{Binding DiffusionCoefficients}" SelectedItem="{Binding SelectedDiffusionCoefficient}" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Функция правой части" FontWeight="Bold" Margin="5"/>
                                <ComboBox ItemsSource="{Binding SourceFunctions}" SelectedItem="{Binding SelectedSourceFunction}" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Метод решения СЛАУ" FontWeight="Bold" Margin="5"/>
                                <ComboBox ItemsSource="{Binding SolverMethods}" SelectedItem="{Binding SelectedSolverMethod}" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Точность расчёта" FontWeight="Bold" Margin="5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Label Content="Допустимая ошибка"/>
                                    <TextBox Width="100" Text="{Binding Tolerance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                            <Button Content="Сохранить" Command="{Binding SaveParametersCommand}"/>
                            <Button Content="Загрузить" Command="{Binding LoadParametersCommand}"/>
                            <Button Content="Сбросить" Command="{Binding ResetParametersCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Граничные условия">
                    <StackPanel Margin="10">
                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Тип граничных условий" FontWeight="Bold" Margin="5"/>
                                <ComboBox ItemsSource="{Binding BoundaryConditionTypes}" SelectedItem="{Binding SelectedBoundaryConditionType}" Margin="5"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Значения граничных условий" FontWeight="Bold" Margin="5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Label Content="Значение"/>
                                    <TextBox Width="100" Text="{Binding BoundaryConditionValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                            <Button Content="Сохранить" Command="{Binding SaveBoundaryConditionsCommand}"/>
                            <Button Content="Загрузить" Command="{Binding LoadBoundaryConditionsCommand}"/>
                            <Button Content="Сбросить" Command="{Binding ResetBoundaryConditionsCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Решение">
                    <StackPanel Margin="10">
                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Управление расчётом" FontWeight="Bold" Margin="5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Button Content="Запустить расчёт" Command="{Binding CalculateCommand}"/>
                                    <Button Content="Остановить расчёт" Command="{Binding StopCalculationCommand}"/>
                                    <Button Content="Сбросить результаты" Command="{Binding ResetResultsCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Состояние расчёта" FontWeight="Bold" Margin="5"/>
                                <ProgressBar Value="{Binding CalculationProgress}" Margin="5"/>
                                <TextBlock Text="{Binding CalculationStatus}" Margin="5"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Результаты">
                    <StackPanel Margin="10">
                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="График решения" FontWeight="Bold" Margin="5"/>
                                <TextBlock Text="[Место для графика решения]" HorizontalAlignment="Center" VerticalAlignment="Center" Height="200"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Таблица значений" FontWeight="Bold" Margin="5"/>
                                <TextBlock Text="[Место для таблицы значений]" HorizontalAlignment="Center" VerticalAlignment="Center" Height="100"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="Экспорт результатов" FontWeight="Bold" Margin="5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Button Content="Экспорт в CSV" Command="{Binding ExportToCsvCommand}"/>
                                    <Button Content="Экспорт в PNG" Command="{Binding ExportToPngCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
