<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="using:App.ViewModels"
        x:Class="App.MainWindow"
        x:DataType="viewmodels:MainWindowViewModel"
        Title="Finite Elements Method"
        Width="1320" Height="860"
        MinWidth="1100" MinHeight="680"
        CanResize="True">

    <DockPanel Background="{StaticResource AppBaseBackground}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Новый проект" Command="{Binding NewProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource AppAccentBackground}" Height="28" Padding="10,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource AppLightTextColor}"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <TabControl Padding="10">
                <TabItem Header="Геометрия и сетка">
                    <StackPanel Margin="10" Spacing="8">
                        <Border BorderBrush="{StaticResource AppWarmAccentBackground}" BorderThickness="1" CornerRadius="4" Padding="8" Background="{StaticResource AppSurfaceBackground}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Тип элемента" FontWeight="Bold"/>
                                <ComboBox ItemsSource="{Binding ElementTypes}"
                                          SelectedItem="{Binding SelectedElementType}"
                                          Width="360"
                                          HorizontalAlignment="Left"/>

                                <TextBlock Text="Путь к файлу сетки"/>
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Content="Выбор файла"
                                            Margin="8,0,0,0"
                                            Click="OnPickMeshFileClick"/>
                                    <TextBox Text="{Binding MeshFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>

                                <TextBlock Text="Текст сетки"/>
                                <TextBox Text="{Binding MeshText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="210"
                                         TextWrapping="NoWrap"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Сохранить текст" Command="{Binding SaveMeshTextCommand}"/>
                                    <Button Content="Очистить текст" Command="{Binding ClearMeshTextCommand}"/>
                                    <Button Content="Шаблон" Command="{Binding LoadMeshTemplateCommand}"/>
                                    <Button Content="Проверить сетку" Command="{Binding ValidateMeshCommand}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding MeshStatus}"/>
                                <TextBlock Text="Диагностика сетки" FontWeight="Bold"/>
                                <TextBox Text="{Binding MeshDiagnosticsText}"
                                         AcceptsReturn="True"
                                         Height="120"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <Button Content="Сохранить" Command="{Binding SaveGeometryCommand}"/>
                                    <Button Content="Загрузить" Command="{Binding LoadGeometryCommand}"/>
                                    <Button Content="Сбросить" Command="{Binding ResetGeometryCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Параметры задачи">
                    <StackPanel Margin="10" Spacing="8">
                        <Border BorderBrush="{StaticResource AppWarmAccentBackground}" 
                                BorderThickness="1" 
                                CornerRadius="4" 
                                Padding="8" 
                                Background="{StaticResource AppSurfaceBackground}">
                            <StackPanel Spacing="10">

                                <TextBlock Text="Коэффициенты и функции" FontWeight="Bold" Margin="0,0,0,8"/>

                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                                        <TextBlock Text="Lambda"/>
                                        <TextBox Text="{Binding SelectedDiffusionCoefficient, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                    
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="Sigma"/>
                                        <TextBox Text="{Binding SelectedSigmaCoefficient, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,10">
                                        <TextBlock Text="f(x,y,t)"/>
                                        <TextBox Text="{Binding SelectedSourceFunction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="u(x,y,t)"/>
                                        <TextBox Text="{Binding SelectedBoundaryFunction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,10">
                                        <TextBlock Text="Метод СЛАУ"/>
                                        <ComboBox ItemsSource="{Binding SolverMethods}" 
                                                  SelectedItem="{Binding SelectedSolverMethod}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="Схема по времени"/>
                                        <ComboBox ItemsSource="{Binding TimeSchemes}" 
                                                  SelectedItem="{Binding SelectedTimeScheme}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,12,10">
                                        <TextBlock Text="Начальное время (t0)"/>
                                        <TextBox Text="{Binding TimeStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="Шаг по времени (dt)"/>
                                        <TextBox Text="{Binding TimeStep, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,12,10">
                                        <TextBlock Text="Количество слоёв"/>
                                        <TextBox Text="{Binding TimeLayerCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="Точность"/>
                                        <TextBox Text="{Binding Tolerance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                                    <Button Content="Сбросить параметры" Command="{Binding ResetParametersCommand}"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Решение">
                    <StackPanel Margin="10" Spacing="8">
                        <Border BorderBrush="{StaticResource AppWarmAccentBackground}" BorderThickness="1" CornerRadius="4" Padding="8" Background="{StaticResource AppSurfaceBackground}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Управление расчетом" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Запустить расчет" Command="{Binding CalculateCommand}"/>
                                    <Button Content="Остановить" Command="{Binding StopCalculationCommand}"/>
                                    <Button Content="Сбросить результаты" Command="{Binding ResetResultsCommand}"/>
                                </StackPanel>
                                <ProgressBar Value="{Binding CalculationProgress}" Height="14"/>
                                <TextBlock Text="{Binding CalculationStatus}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Результаты и логи">
                    <StackPanel Margin="10" Spacing="8">
                        <Border BorderBrush="{StaticResource AppWarmAccentBackground}" BorderThickness="1" CornerRadius="4" Padding="8" Background="{StaticResource AppSurfaceBackground}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Экспорт" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Экспорт CSV" Command="{Binding ExportToCsvCommand}"/>
                                    <Button Content="Экспорт сводки" Command="{Binding ExportToPngCommand}"/>
                                </StackPanel>
                                <TextBlock Text="Поле отрисовки" FontWeight="Bold"/>
                                <Border BorderBrush="{StaticResource AppWarmAccentBackground}" BorderThickness="1" CornerRadius="4" Height="220" Padding="8">
                                    <TextBlock Text="[Место для графика решения]" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Сводка расчета" FontWeight="Bold"/>
                                <TextBox Text="{Binding ValidationSummary}"
                                          Height="80"
                                          IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"/>
                                <TextBlock Text="Журнал" FontWeight="Bold"/>
                                <TextBox Text="{Binding ExecutionLog}"
                                         Height="260"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Очистить лог" Command="{Binding ClearLogCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </ScrollViewer>
    </DockPanel>
</Window>
