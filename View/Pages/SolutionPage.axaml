<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="using:App.ViewModels"
             x:Class="App.Pages.SolutionPage"
             x:DataType="viewmodels:MainWindowViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10" Spacing="8">
            <Border BorderThickness="1" CornerRadius="4" Padding="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Управление расчётом" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Запустить расчёт" Command="{Binding CalculateCommand}"/>
                        <Button Content="Остановить" Command="{Binding StopCalculationCommand}"/>
                        <Button Content="Сбросить результаты" Command="{Binding ResetResultsCommand}"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding CalculationProgress}" Height="14"/>
                    <TextBlock Text="{Binding CalculationStatus}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
