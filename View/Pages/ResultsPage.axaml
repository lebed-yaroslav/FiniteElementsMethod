<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="using:App.ViewModels"
             x:Class="App.Pages.ResultsPage"
             x:DataType="viewmodels:MainWindowViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10" Spacing="8">
            <Border BorderThickness="1" CornerRadius="4" Padding="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Экспорт" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Экспорт CSV" Command="{Binding ExportToCsvCommand}"/>
                        <Button Content="Экспорт сводки" Command="{Binding ExportToPngCommand}"/>
                    </StackPanel>

                    <TextBlock Text="Визуализация поля решения" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="8"
                          RowSpacing="6">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Слой" VerticalAlignment="Center"/>
                        <Slider x:Name="LayerSlider"
                                Grid.Row="0"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="0"
                                Value="0"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"/>
                        <Button Grid.Row="0" Grid.Column="2" Width="34" Content="◀" Click="OnPrevLayerClick"/>
                        <Button Grid.Row="0" Grid.Column="3" Width="34" Content="▶" Click="OnNextLayerClick"/>
                        <TextBlock x:Name="LayerStatusText"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="4"
                                   Text="Нет данных"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="Выбранная вершина:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SelectedVertexText"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="—"/>
                    </Grid>

                    <TextBlock Text="Нажмите на вершину, чтобы увидеть её номер и значение."
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Пространственная сетка и поле u(x,y)" FontWeight="Bold"/>
                    <Border BorderThickness="1" CornerRadius="1">
                        <Image x:Name="SpatialImage"
                               Width="780"
                               Height="520"
                               Stretch="None"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               PointerPressed="OnSpatialImagePointerPressed"/>
                    </Border>

                    <TextBlock Text="Сводка расчета" FontWeight="Bold"/>
                    <TextBox Text="{Binding ValidationSummary}"
                             Height="80"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>

                    <TextBlock Text="Журнал" FontWeight="Bold"/>
                    <TextBox Text="{Binding ExecutionLog}"
                             Height="260"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Очистить лог" Command="{Binding ClearLogCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
