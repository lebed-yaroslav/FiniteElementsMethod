<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="using:App.ViewModels"
             x:Class="App.Pages.GeometryMeshPage"
             x:DataType="viewmodels:MainWindowViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10" Spacing="8">
            <Border BorderThickness="1" CornerRadius="4" Padding="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Тип элемента" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding ElementTypes}"
                              SelectedItem="{Binding SelectedElementType}"
                              Width="360"
                              HorizontalAlignment="Left"/>

                    <TextBlock Text="Путь к файлу сетки"/>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="Выбор файла"
                                Margin="8,0,0,0"
                                Command="{Binding PickMeshFileCommand}"/>
                        <TextBox Text="{Binding MeshFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <TextBlock Text="Текст сетки"/>
                    <TextBox Text="{Binding MeshText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="210"
                             TextWrapping="NoWrap"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Сохранить текст" Command="{Binding SaveMeshTextCommand}"/>
                        <Button Content="Очистить текст" Command="{Binding ClearMeshTextCommand}"/>
                        <Button Content="Шаблон" Command="{Binding LoadMeshTemplateCommand}"/>
                        <Button Content="Проверить сетку" Command="{Binding ValidateMeshCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding MeshStatus}"/>
                    <TextBlock Text="Диагностика сетки" FontWeight="Bold"/>
                    <TextBox Text="{Binding MeshDiagnosticsText}"
                             AcceptsReturn="True"
                             Height="120"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Сохранить" Command="{Binding SaveGeometryCommand}"/>
                        <Button Content="Загрузить" Command="{Binding LoadGeometryCommand}"/>
                        <Button Content="Сбросить" Command="{Binding ResetGeometryCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
